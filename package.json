{
  "name": "clougence-officialsite-new",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "SITE_BRAND=bladepipe docusaurus start",
    "start:clougence": "SITE_BRAND=clougence docusaurus start --config docusaurus.config.clougence.ts --locale zh",
    "start:dm": "SITE_BRAND=clouddm docusaurus start --config docusaurus.config.dm.ts --locale zh",
    "build": "DEPLOYMENT_ENV=production SITE_BRAND=bladepipe docusaurus build",
    "build:staging": "DEPLOYMENT_ENV=staging SITE_BRAND=bladepipe docusaurus build",
    "build:dm": "DEPLOYMENT_ENV=production SITE_BRAND=clouddm docusaurus build --config docusaurus.config.dm.ts",
    "build:dm:staging": "DEPLOYMENT_ENV=staging SITE_BRAND=clouddm docusaurus build --config docusaurus.config.dm.ts",
    "build:clougence": "DEPLOYMENT_ENV=production SITE_BRAND=clougence docusaurus build --config docusaurus.config.clougence.ts",
    "build:clougence:staging": "DEPLOYMENT_ENV=staging  SITE_BRAND=clougence docusaurus build --config docusaurus.config.clougence.ts",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.3",
    "@docusaurus/core": "3.8.1",
    "@docusaurus/plugin-content-docs": "^3.8.1",
    "@docusaurus/preset-classic": "3.8.1",
    "@easyops-cn/docusaurus-search-local": "^0.52.2",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/react": "^3.0.0",
    "antd": "^4.24.16",
    "axios": "^1.10.0",
    "clsx": "^2.0.0",
    "i18next": "^25.3.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.2.0",
    "react-cookie": "^8.0.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^15.5.3",
    "react-markdown": "^10.1.0",
    "sm-crypto": "^0.3.13",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.8.1",
    "@docusaurus/tsconfig": "3.8.1",
    "@docusaurus/types": "3.8.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.7",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
